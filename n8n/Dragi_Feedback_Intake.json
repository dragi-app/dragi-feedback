      "notesInFlow": true,
      "notes": "Вставте Google Sheet ID, назву аркуша та Google Drive folder ID. Облікові дані Google вибираються окремо у відповідних нодах."
    },
    {
      "parameters": {
        "jsCode": "const item = $input.first();\nconst input = item.json || {};\nconst body = input.body && typeof input.body === 'object' ? input.body : input;\nlet rawPayload = body.payload ?? input.payload;\nif (rawPayload == null && body.schema_version) rawPayload = body;\nif (rawPayload == null) throw new Error('PAYLOAD_MISSING');\nlet payload;\ntry {\n  payload = typeof rawPayload === 'string' ? JSON.parse(rawPayload) : rawPayload;\n} catch {\n  throw new Error('PAYLOAD_INVALID_JSON');\n}\nif (!payload || typeof payload !== 'object' || Array.isArray(payload)) throw new Error('PAYLOAD_INVALID');\nconst allowedCategories = new Set(['AUDIO', 'VISUAL', 'CONTENT', 'EXERCISE', 'TECHNICAL', 'OTHER']);\nconst safeCell = (value, max = 1200) => {\n  if (value === null || value === undefined) return '';\n  let text = String(value).replace(/\\u0000/g, '').trim().slice(0, max);\n  if (/^[=+\\-@]/.test(text)) text = `\\'${text}`;\n  return text;\n};\nconst feedbackId = safeCell(payload.feedback_id, 80);\nconst category = safeCell(payload.issue_category, 32).toUpperCase();\nconst issueCode = safeCell(payload.issue_code, 80).toUpperCase();\nconst uiLang = safeCell(payload.ui_lang || 'uk', 12).toLowerCase();\nconst contentId = safeCell(payload.content_id, 120);\nconst description = safeCell(payload.description, 1200);\nconst email = safeCell(payload.email, 254);\nif (!feedbackId || !/^[a-zA-Z0-9._:-]{8,80}$/.test(feedbackId)) throw new Error('FEEDBACK_ID_INVALID');\nif (!allowedCategories.has(category)) throw new Error('ISSUE_CATEGORY_INVALID');\nif (!issueCode || !issueCode.startsWith(category + '_')) throw new Error('ISSUE_CODE_INVALID');\nif (!/^[a-z]{2,3}$/.test(uiLang)) throw new Error('UI_LANG_INVALID');\nif (contentId && !/^[a-zA-Z0-9._:-]{1,120}$/.test(contentId)) throw new Error('CONTENT_ID_INVALID');\nif (email && !/^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/.test(email)) throw new Error('EMAIL_INVALID');\nif (category === 'OTHER' && !description && !item.binary?.audio) throw new Error('OTHER_DETAILS_REQUIRED');\nconst audioSize = Number(payload.audio?.size_bytes || 0);\nif (audioSize > 5 * 1024 * 1024) throw new Error('AUDIO_TOO_LARGE');\nconst origin = safeCell(input.headers?.origin, 200);\nconst allowedOrigin = safeCell(input.config_allowed_origin, 200);\nif (origin && allowedOrigin && origin !== allowedOrigin) throw new Error('ORIGIN_NOT_ALLOWED');\nconst audioMime = safeCell(payload.audio?.mime_type || item.binary?.audio?.mimeType, 100);\nconst extension = audioMime.includes('mp4') ? 'm4a' : audioMime.includes('ogg') ? 'ogg' : 'webm';\nconst priority = category === 'TECHNICAL' ? 'HIGH' : category === 'OTHER' ? 'LOW' : 'NORMAL';\nreturn [{\n  json: {\n    _config_sheet_id: input.config_sheet_id,\n    _config_sheet_name: input.config_sheet_name,\n    _config_audio_folder_id: input.config_audio_folder_id,\n    _config_allowed_origin: allowedOrigin,\n    schema_version: String(payload.schema_version || 1),\n    feedback_id: feedbackId,\n    received_at_utc: new Date().toISOString(),\n    status: 'NEW',\n    priority,\n    ui_lang: uiLang,\n    content_id: contentId,\n    issue_category: category,\n    issue_code: issueCode,\n    description,\n    audio_url: '',\n    audio_status: item.binary?.audio ? 'PENDING_UPLOAD' : 'NONE',\n    audio_mime_type: audioMime,\n    audio_size_bytes: audioSize || '',\n    audio_duration_seconds: Number(payload.audio?.duration_seconds || 0) || '',\n    email,\n    contact_allowed: email ? 'TRUE' : 'FALSE',\n    platform: safeCell(payload.platform, 40),\n    app_version: safeCell(payload.app_version, 40),\n    page_path: safeCell(payload.page_context?.path, 300),\n    user_agent: safeCell(payload.page_context?.user_agent, 500),\n    source_origin: origin,\n    assigned_to: '',\n    resolution_note: '',\n    resolved_at: '',\n    duplicate_of: '',\n    has_audio: Boolean(item.binary?.audio),\n    audio_file_name: `${feedbackId}.${extension}`\n  },\n  binary: item.binary\n}];"
      },
