    {
      "parameters": {
        "jsCode": "const current = $input.first();\nconst base = $('Normalize & Validate').first().json;\nconst drive = current.json || {};\nconst fileId = drive.id || drive.fileId || '';\nreturn [{\n  json: {\n    ...base,\n    audio_url: fileId ? `https://drive.google.com/file/d/${fileId}/view` : '',\n    audio_status: fileId ? 'UPLOADED' : 'UPLOAD_FAILED'\n  },\n  binary: current.binary\n}];"
      },
